# ============================================================================
# EMAIL CATEGORIZATION SYSTEM - ENVIRONMENT VARIABLES (TEMPLATE)
# Copy this file to .env and update with your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# STEP 1: DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@host.region.aws.neon.tech/dbname?sslmode=require
DB_HOST=your-neon-host.region.aws.neon.tech
DB_PORT=5432
DB_NAME=email_categorization_db
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSLMODE=require

# ----------------------------------------------------------------------------
# STEP 5: API CONFIGURATION
# ----------------------------------------------------------------------------

# Application Settings
APP_NAME=Email Categorization API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=false
WORKERS=4

# Database Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Authentication & Security (REPLACE WITH GENERATED VALUES)
SECRET_KEY=replace-with-generated-secret-key
API_KEY_1=replace-with-generated-api-key-1
API_KEY_2=replace-with-generated-api-key-2

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS Settings
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Model Configuration
MODEL_PATH=../training/artifacts/best_model.pkl
VECTORIZER_PATH=../training/artifacts/tfidf_vectorizer.pkl
MAX_EMAIL_LENGTH=10000

# Batch Processing
MAX_BATCH_SIZE=100
BATCH_TIMEOUT=300

# Cache Settings
CACHE_ENABLED=true
CACHE_TTL=300

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100