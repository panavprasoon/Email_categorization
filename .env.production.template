# Production Environment Variables Template
# Copy to your deployment platform and replace placeholders.

# Core
ENVIRONMENT=production
DEBUG=false
APP_NAME=Email Categorization API
APP_VERSION=1.0.0

# API server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Security
SECRET_KEY=replace-with-strong-secret
API_KEY_1=replace-with-primary-api-key
API_KEY_2=replace-with-secondary-api-key

# Frontend -> API
API_BASE_URL=https://your-api-domain.com
API_KEY=replace-with-primary-api-key
API_TIMEOUT_SECONDS=30

# CORS
CORS_ENABLED=true
CORS_ORIGINS=https://your-frontend-domain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/api.log

# Model
MODEL_PATH=artifacts/models/best_model.pkl
VECTORIZER_PATH=artifacts/vectorizers/tfidf_vectorizer.pkl
